"use client";
import { useEffect, useRef } from "react";
import { useTheme } from "@/components/ThemeProvider";

// Each icon drawn directly with canvas 2D API — no image loading needed
type IconDef = { name: string; color: string; draw: (ctx: CanvasRenderingContext2D, s: number) => void };

const ICONS: IconDef[] = [
  {
    name: "React", color: "#61DAFB",
    draw(ctx, s) {
      const r = s * 0.15;
      ctx.beginPath(); ctx.arc(0, 0, r, 0, Math.PI * 2); ctx.fill();
      for (let i = 0; i < 3; i++) {
        ctx.save(); ctx.rotate((i * Math.PI) / 3);
        ctx.beginPath();
        ctx.ellipse(0, 0, s * 0.45, s * 0.15, 0, 0, Math.PI * 2);
        ctx.strokeStyle = ctx.fillStyle as string; ctx.lineWidth = s * 0.06;
        ctx.stroke(); ctx.restore();
      }
    },
  },
  {
    name: "TypeScript", color: "#3178C6",
    draw(ctx, s) {
      const h = s * 0.42;
      ctx.beginPath();
      ctx.roundRect(-h, -h, h * 2, h * 2, s * 0.12);
      ctx.globalAlpha *= 0.25; ctx.fill(); ctx.globalAlpha /= 0.25;
      ctx.strokeStyle = ctx.fillStyle as string; ctx.lineWidth = s * 0.07;
      ctx.stroke();
      ctx.lineWidth = s * 0.09; ctx.lineCap = "round";
      // T
      ctx.beginPath(); ctx.moveTo(-h * 0.55, -h * 0.2); ctx.lineTo(h * 0.15, -h * 0.2); ctx.stroke();
      ctx.beginPath(); ctx.moveTo(-h * 0.2, -h * 0.2); ctx.lineTo(-h * 0.2, h * 0.5); ctx.stroke();
      // S
      ctx.lineWidth = s * 0.075;
      ctx.beginPath(); ctx.arc(h * 0.5, h * 0.1, h * 0.22, Math.PI * 1.5, Math.PI * 0.5); ctx.stroke();
      ctx.beginPath(); ctx.arc(h * 0.5, h * 0.38, h * 0.22, Math.PI * 0.5, Math.PI * 1.5, true); ctx.stroke();
    },
  },
  {
    name: "Node.js", color: "#339933",
    draw(ctx, s) {
      const h = s * 0.42;
      ctx.lineWidth = s * 0.07; ctx.strokeStyle = ctx.fillStyle as string; ctx.lineCap = "round"; ctx.lineJoin = "round";
      ctx.beginPath();
      ctx.moveTo(0, -h); ctx.lineTo(h, -h * 0.5); ctx.lineTo(h, h * 0.5);
      ctx.lineTo(0, h); ctx.lineTo(-h, h * 0.5); ctx.lineTo(-h, -h * 0.5);
      ctx.closePath(); ctx.stroke();
      ctx.beginPath(); ctx.moveTo(0, -h); ctx.lineTo(0, 0); ctx.lineTo(h, h * 0.5); ctx.stroke();
      ctx.beginPath(); ctx.moveTo(-h, -h * 0.5); ctx.lineTo(0, 0); ctx.lineTo(0, h); ctx.stroke();
    },
  },
  {
    name: "Docker", color: "#2496ED",
    draw(ctx, s) {
      ctx.lineWidth = s * 0.07; ctx.strokeStyle = ctx.fillStyle as string; ctx.lineJoin = "round";
      const bw = s * 0.18, bh = s * 0.16, gap = s * 0.04;
      const rows = [[-s*0.32, -s*0.1], [-s*0.32+bw+gap, -s*0.1], [-s*0.32+2*(bw+gap), -s*0.1], [-s*0.32+(bw+gap), -s*0.1-bh-gap], [-s*0.32+2*(bw+gap), -s*0.1-bh-gap]];
      rows.forEach(([x, y]) => { ctx.beginPath(); ctx.roundRect(x, y, bw, bh, 2); ctx.stroke(); });
      ctx.beginPath(); ctx.moveTo(-s*0.4, s*0.08); ctx.lineTo(s*0.4, s*0.08);
      ctx.moveTo(s*0.32, s*0.08); ctx.arc(s*0.32, -s*0.04, s*0.12, Math.PI*0.5, 0, true);
      ctx.stroke();
    },
  },
  {
    name: "Go", color: "#00ADD8",
    draw(ctx, s) {
      ctx.lineWidth = s * 0.08; ctx.strokeStyle = ctx.fillStyle as string; ctx.lineCap = "round";
      // Go logo simplified as two circles with a line
      ctx.beginPath(); ctx.arc(-s * 0.2, 0, s * 0.28, 0, Math.PI * 2); ctx.stroke();
      ctx.beginPath(); ctx.moveTo(-s * 0.08, 0); ctx.lineTo(s * 0.42, 0); ctx.stroke();
      ctx.beginPath(); ctx.arc(s * 0.3, 0, s * 0.14, 0, Math.PI * 2); ctx.fill();
      ctx.fillStyle = "transparent"; // reset
    },
  },
  {
    name: "PostgreSQL", color: "#4169E1",
    draw(ctx, s) {
      ctx.lineWidth = s * 0.07; ctx.strokeStyle = ctx.fillStyle as string;
      // 3 stacked ellipses (database)
      [-s*0.25, 0, s*0.25].forEach((y, i) => {
        ctx.beginPath(); ctx.ellipse(0, y, s * 0.38, s * 0.14, 0, 0, Math.PI * 2); ctx.stroke();
      });
      ctx.beginPath(); ctx.moveTo(-s*0.38, -s*0.25); ctx.lineTo(-s*0.38, s*0.25); ctx.stroke();
      ctx.beginPath(); ctx.moveTo(s*0.38, -s*0.25); ctx.lineTo(s*0.38, s*0.25); ctx.stroke();
    },
  },
  {
    name: "Redis", color: "#FF4438",
    draw(ctx, s) {
      ctx.lineWidth = s * 0.07; ctx.strokeStyle = ctx.fillStyle as string; ctx.lineJoin = "round";
      [[-s*0.22, -s*0.1], [0, s*0.05], [s*0.22, -s*0.2]].forEach(([y1, y2], i) => {});
      // Stacked layers
      const drawLayer = (yOff: number) => {
        ctx.beginPath(); ctx.moveTo(0, -s*0.18+yOff); ctx.lineTo(s*0.38, -s*0.04+yOff);
        ctx.lineTo(0, s*0.1+yOff); ctx.lineTo(-s*0.38, -s*0.04+yOff); ctx.closePath(); ctx.stroke();
      };
      drawLayer(-s*0.25); drawLayer(0); drawLayer(s*0.22);
    },
  },
  {
    name: "AWS", color: "#FF9900",
    draw(ctx, s) {
      ctx.lineWidth = s * 0.07; ctx.strokeStyle = ctx.fillStyle as string; ctx.lineCap = "round";
      // Cloud shape
      ctx.beginPath();
      ctx.arc(-s*0.12, -s*0.05, s*0.22, Math.PI, 0);
      ctx.arc(s*0.15, -s*0.08, s*0.16, Math.PI, 0);
      ctx.arc(s*0.05, s*0.1, s*0.12, 0, Math.PI);
      ctx.closePath(); ctx.stroke();
      // Arrow down
      ctx.beginPath(); ctx.moveTo(0, s*0.18); ctx.lineTo(0, s*0.42);
      ctx.moveTo(-s*0.14, s*0.3); ctx.lineTo(0, s*0.42); ctx.lineTo(s*0.14, s*0.3); ctx.stroke();
    },
  },
  {
    name: "GraphQL", color: "#E10098",
    draw(ctx, s) {
      ctx.lineWidth = s * 0.055; ctx.strokeStyle = ctx.fillStyle as string;
      const r = s * 0.38, ri = s * 0.12;
      const pts = Array.from({length: 6}, (_, i) => [r * Math.cos(i*Math.PI/3 - Math.PI/6), r * Math.sin(i*Math.PI/3 - Math.PI/6)]);
      pts.forEach(([x,y]) => { ctx.beginPath(); ctx.arc(x, y, ri, 0, Math.PI*2); ctx.stroke(); });
      ctx.beginPath();
      pts.forEach(([x,y], i) => {
        const [nx,ny] = pts[(i+2)%6]; ctx.moveTo(x,y); ctx.lineTo(nx,ny);
      });
      ctx.stroke();
    },
  },
  {
    name: "Next.js", color: "#888888",
    draw(ctx, s) {
      ctx.lineWidth = s * 0.07; ctx.strokeStyle = ctx.fillStyle as string;
      ctx.beginPath(); ctx.arc(0, 0, s * 0.4, 0, Math.PI * 2); ctx.stroke();
      ctx.lineWidth = s * 0.1; ctx.lineCap = "round"; ctx.lineJoin = "round";
      ctx.beginPath(); ctx.moveTo(-s*0.18, -s*0.25); ctx.lineTo(-s*0.18, s*0.25);
      ctx.lineTo(s*0.22, s*0.25); ctx.stroke();
      ctx.beginPath(); ctx.moveTo(-s*0.18, -s*0.25); ctx.lineTo(s*0.22, s*0.25); ctx.stroke();
    },
  },
  {
    name: "Git", color: "#F05032",
    draw(ctx, s) {
      ctx.lineWidth = s * 0.07; ctx.strokeStyle = ctx.fillStyle as string; ctx.lineCap = "round"; ctx.lineJoin = "round";
      // Git branch icon
      ctx.beginPath(); ctx.arc(-s*0.2, -s*0.25, s*0.11, 0, Math.PI*2); ctx.stroke();
      ctx.beginPath(); ctx.arc(-s*0.2, s*0.25, s*0.11, 0, Math.PI*2); ctx.stroke();
      ctx.beginPath(); ctx.arc(s*0.2, 0, s*0.11, 0, Math.PI*2); ctx.stroke();
      ctx.beginPath(); ctx.moveTo(-s*0.2, -s*0.14); ctx.lineTo(-s*0.2, s*0.14); ctx.stroke();
      ctx.beginPath(); ctx.moveTo(-s*0.2, -s*0.14); ctx.bezierCurveTo(-s*0.2, -s*0.25, s*0.2, -s*0.25, s*0.2, 0); ctx.stroke();
    },
  },
  {
    name: "Tailwind", color: "#06B6D4",
    draw(ctx, s) {
      ctx.lineWidth = s * 0.08; ctx.strokeStyle = ctx.fillStyle as string; ctx.lineCap = "round";
      // Two wave shapes
      const wave = (yBase: number) => {
        ctx.beginPath();
        ctx.moveTo(-s*0.4, yBase);
        ctx.bezierCurveTo(-s*0.2, yBase-s*0.2, 0, yBase-s*0.2, s*0.0, yBase);
        ctx.bezierCurveTo(s*0.2, yBase+s*0.2, s*0.4, yBase+s*0.2, s*0.4, yBase);
        ctx.stroke();
      };
      wave(-s*0.1); wave(s*0.12);
    },
  },
];

type Particle = {
  x: number; y: number;
  vx: number; vy: number;
  size: number;
  iconIdx: number;
  rotation: number;
  rotSpeed: number;
  opacity: number;
};

export default function FloatingIcons() {
  const canvasRef = useRef<HTMLCanvasElement>(null);
  const { theme } = useTheme();
  const themeRef = useRef(theme);
  useEffect(() => { themeRef.current = theme; }, [theme]);

  useEffect(() => {
    const canvas = canvasRef.current;
    if (!canvas) return;
    const ctx = canvas.getContext("2d")!;

    let W = window.innerWidth;
    let H = Math.max(document.body.scrollHeight, window.innerHeight);
    canvas.width = W; canvas.height = H;

    const onResize = () => {
      W = window.innerWidth;
      H = Math.max(document.body.scrollHeight, window.innerHeight);
      canvas.width = W; canvas.height = H;
    };
    window.addEventListener("resize", onResize);

    const COUNT = 20;
    const particles: Particle[] = Array.from({ length: COUNT }, (_, i) => ({
      x: 60 + Math.random() * (W - 120),
      y: 60 + Math.random() * (H - 120),
      vx: (Math.random() - 0.5) * 0.55,
      vy: (Math.random() - 0.5) * 0.55,
      size: 20 + Math.random() * 18,
      iconIdx: Math.floor(Math.random() * ICONS.length),
      rotation: Math.random() * Math.PI * 2,
      rotSpeed: (Math.random() - 0.5) * 0.007,
      opacity: 0.055 + Math.random() * 0.07,
    }));

    let raf: number;

    const draw = () => {
      ctx.clearRect(0, 0, W, H);
      const opacityMul = themeRef.current === "light" ? 0.55 : 1;

      particles.forEach(p => {
        p.x += p.vx;
        p.y += p.vy;
        p.rotation += p.rotSpeed;

        const half = p.size * 0.55;
        if (p.x < half) { p.x = half; p.vx = Math.abs(p.vx); }
        if (p.x > W - half) { p.x = W - half; p.vx = -Math.abs(p.vx); }
        if (p.y < half) { p.y = half; p.vy = Math.abs(p.vy); }
        if (p.y > H - half) { p.y = H - half; p.vy = -Math.abs(p.vy); }

        ctx.save();
        ctx.globalAlpha = p.opacity * opacityMul;
        ctx.translate(p.x, p.y);
        ctx.rotate(p.rotation);
        ctx.fillStyle = ICONS[p.iconIdx].color;
        ctx.strokeStyle = ICONS[p.iconIdx].color;
        ICONS[p.iconIdx].draw(ctx, p.size);
        ctx.restore();
      });

      raf = requestAnimationFrame(draw);
    };

    draw();
    return () => {
      window.removeEventListener("resize", onResize);
      cancelAnimationFrame(raf);
    };
  }, []);

  return (
    <canvas
      ref={canvasRef}
      style={{
        position: "fixed",
        top: 0, left: 0,
        width: "100%", height: "100%",
        pointerEvents: "none",
        zIndex: 1,
      }}
    />
  );
}
